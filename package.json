              <li><code style="font-family:var(--mono);color:var(--green)">ai:summary-ready</code></li>
              <li><code style="font-family:var(--mono);color:var(--green)">notification:new</code></li>
              <li><code style="font-family:var(--mono);color:var(--green)">presence:user-updated</code></li>
            </ul></div>
          </div>
          <div class="ph2"><div class="ph2-dot"></div>WebRTC SFU Architecture</div>
          <div class="g3">
            <div class="card"><div class="ph3">Mediasoup SFU</div><ul class="fl">
              <li>Each participant → 1 upstream track to SFU</li>
              <li>SFU selectively forwards to subscribers</li>
              <li>Simulcast: 1080p / 480p / 240p layers</li>
              <li>Bandwidth-adaptive layer switching</li>
              <li>CPU/BW-aware track selection per subscriber</li>
              <li>Active speaker detection → prioritise HD</li>
              <li>Up to 500 participants per Worker</li>
            </ul></div>
            <div class="card"><div class="ph3">STUN / TURN</div><ul class="fl">
              <li>STUN: global anycast, UDP 3478</li>
              <li>TURN: regional fallback (US/EU/APAC)</li>
              <li>TURN over TCP 443 (firewall bypass)</li>
              <li>HMAC-SHA1 time-limited credentials</li>
              <li>ICE trickle for fast peer connection</li>
              <li>ICE restart on network change</li>
            </ul></div>
            <div class="card"><div class="ph3">Audio Processing</div><ul class="fl">
              <li>Opus codec (48 kHz, stereo)</li>
              <li>Echo cancellation (AEC3)</li>
              <li>AI noise suppression (RNNoise)</li>
              <li>Auto Gain Control (AGC2)</li>
              <li>Voice Activity Detection (VAD)</li>
              <li>Original sound mode (musicians)</li>
            </ul></div>
          </div>
        </div>

        <!-- ── WEBHOOKS ── -->
        <div id="panel-webhooks" class="panel">
          <div class="ph1">Webhook Events</div>
          <div class="pdesc">Subscribe at <code style="font-family:var(--mono);color:var(--accent3);background:var(--bg3);padding:2px 8px;border-radius:4px">POST /admin/webhooks</code>. All payloads are signed with <code style="font-family:var(--mono);color:var(--amber)">HMAC-SHA256</code> in the <code style="font-family:var(--mono);color:var(--green)">X-FasaFas-Signature</code> header.</div>
          <div class="card">
            <table style="width:100%;border-collapse:collapse;font-size:13px">
              <thead><tr style="border-bottom:1px solid var(--border)"><th style="padding:8px 12px;text-align:left;color:var(--text3);font-size:11px;text-transform:uppercase;letter-spacing:.5px">Event</th><th style="padding:8px 12px;text-align:left;color:var(--text3);font-size:11px;text-transform:uppercase;letter-spacing:.5px">Key Payload Fields</th></tr></thead>
              <tbody>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">meeting.started</td><td style="padding:8px 12px;color:var(--text2);font-size:12px">meeting_id, host_id, topic, start_time</td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">meeting.ended</td><td style="padding:8px 12px;color:var(--text2);font-size:12px">meeting_id, duration_seconds, participant_count</td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">meeting.participant_joined</td><td style="padding:8px 12px;color:var(--text2);font-size:12px">participant_id, user_id, join_time, device</td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">meeting.recording.completed</td><td style="padding:8px 12px;color:var(--text2);font-size:12px">recording_url, file_size, format, duration</td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">meeting.summary.completed</td><td style="padding:8px 12px;color:var(--text2);font-size:12px">summary_text, action_items[], chapters[]</td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">chat.message.sent</td><td style="padding:8px 12px;color:var(--text2);font-size:12px">message_id, channel_id, sender_id, content</td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">user.created</td><td style="padding:8px 12px;color:var(--text2);font-size:12px">user_id, email, role, plan, created_at</td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">user.deactivated</td><td style="padding:8px 12px;color:var(--text2);font-size:12px">user_id, deactivated_by, reason</td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">phone.call.started</td><td style="padding:8px 12px;color:var(--text2);font-size:12px">call_id, caller, callee, direction</td></tr>
