          </div>
        </div>

        <!-- ── DATABASE SCHEMA ── -->
        <div id="panel-schema" class="panel">
          <div class="ph1">Database Schema</div>
          <div class="pdesc">PostgreSQL 16 · All tables include <code style="font-family:var(--mono);color:var(--green)">created_at</code>, <code style="font-family:var(--mono);color:var(--green)">updated_at</code>, and soft-delete via <code style="font-family:var(--mono);color:var(--green)">deleted_at</code>. Multi-tenant via <code style="font-family:var(--mono);color:var(--teal)">account_id</code> + Row-Level Security.</div>

          <div class="schema"><div class="schema-head">🟡 accounts (tenants)</div>
            <div class="schema-row"><span class="sr-field pk">id</span><span class="sr-type">UUID PK</span><span class="sr-note">gen_random_uuid()</span></div>
            <div class="schema-row"><span class="sr-field">name</span><span class="sr-type">VARCHAR(200)</span><span class="sr-note">organization name</span></div>
            <div class="schema-row"><span class="sr-field">account_number</span><span class="sr-type">BIGINT UNIQUE</span><span class="sr-note">10-digit, auto-generated</span></div>
            <div class="schema-row"><span class="sr-field">plan</span><span class="sr-type">ENUM</span><span class="sr-note">basic|pro|business|enterprise</span></div>
            <div class="schema-row"><span class="sr-field">max_participants</span><span class="sr-type">INTEGER</span><span class="sr-note">per plan limit</span></div>
            <div class="schema-row"><span class="sr-field">cloud_storage_bytes</span><span class="sr-type">BIGINT</span><span class="sr-note">allocated quota</span></div>
            <div class="schema-row"><span class="sr-field">sso_config</span><span class="sr-type">JSONB</span><span class="sr-note">SAML metadata, IdP URL, cert</span></div>
            <div class="schema-row"><span class="sr-field">data_region</span><span class="sr-type">VARCHAR(20)</span><span class="sr-note">us-east|eu-west|ap-southeast</span></div>
            <div class="schema-row"><span class="sr-field">stripe_customer_id</span><span class="sr-type">VARCHAR(100)</span><span class="sr-note">Stripe customer reference</span></div>
          </div>

          <div class="schema" style="margin-top:10px"><div class="schema-head">🟡 users</div>
            <div class="schema-row"><span class="sr-field pk">id</span><span class="sr-type">UUID PK</span><span class="sr-note"></span></div>
            <div class="schema-row"><span class="sr-field fk">account_id</span><span class="sr-type">UUID FK</span><span class="sr-note">→ accounts.id</span></div>
            <div class="schema-row"><span class="sr-field">email</span><span class="sr-type">VARCHAR(320)</span><span class="sr-note">UNIQUE, indexed</span></div>
            <div class="schema-row"><span class="sr-field">display_name, first_name, last_name</span><span class="sr-type">VARCHAR</span><span class="sr-note"></span></div>
            <div class="schema-row"><span class="sr-field">password_hash</span><span class="sr-type">VARCHAR(72)</span><span class="sr-note">bcrypt cost=12</span></div>
            <div class="schema-row"><span class="sr-field">role</span><span class="sr-type">ENUM</span><span class="sr-note">member|admin|owner</span></div>
            <div class="schema-row"><span class="sr-field">plan_type</span><span class="sr-type">ENUM</span><span class="sr-note">basic|pro|business|enterprise</span></div>
            <div class="schema-row"><span class="sr-field">personal_meeting_id</span><span class="sr-type">BIGINT UNIQUE</span><span class="sr-note">10-digit PMR</span></div>
            <div class="schema-row"><span class="sr-field">mfa_enabled, mfa_secret</span><span class="sr-type">BOOLEAN / VARCHAR</span><span class="sr-note">TOTP secret encrypted</span></div>
            <div class="schema-row"><span class="sr-field">timezone, language</span><span class="sr-type">VARCHAR</span><span class="sr-note">IANA tz / BCP-47</span></div>
            <div class="schema-row"><span class="sr-field">status</span><span class="sr-type">ENUM</span><span class="sr-note">active|pending|suspended|deactivated</span></div>
            <div class="schema-row"><span class="sr-field">last_login_at, last_login_ip</span><span class="sr-type">TIMESTAMPTZ / INET</span><span class="sr-note"></span></div>
          </div>

          <div class="schema" style="margin-top:10px"><div class="schema-head">🟡 meetings</div>
            <div class="schema-row"><span class="sr-field pk">id</span><span class="sr-type">UUID PK</span><span class="sr-note"></span></div>
            <div class="schema-row"><span class="sr-field fk">host_id, account_id</span><span class="sr-type">UUID FK</span><span class="sr-note">→ users.id / accounts.id</span></div>
            <div class="schema-row"><span class="sr-field">topic</span><span class="sr-type">VARCHAR(500)</span><span class="sr-note">NOT NULL</span></div>
            <div class="schema-row"><span class="sr-field">meeting_number</span><span class="sr-type">BIGINT UNIQUE</span><span class="sr-note">11-digit meeting ID</span></div>
            <div class="schema-row"><span class="sr-field">join_url</span><span class="sr-type">TEXT</span><span class="sr-note">invite link with embedded token</span></div>
            <div class="schema-row"><span class="sr-field">password</span><span class="sr-type">VARCHAR(10)</span><span class="sr-note">passcode (hashed)</span></div>
            <div class="schema-row"><span class="sr-field">status</span><span class="sr-type">ENUM</span><span class="sr-note">scheduled|started|ended|cancelled</span></div>
            <div class="schema-row"><span class="sr-field">start_time, actual_start, actual_end</span><span class="sr-type">TIMESTAMPTZ</span><span class="sr-note"></span></div>
            <div class="schema-row"><span class="sr-field">duration_minutes</span><span class="sr-type">INTEGER</span><span class="sr-note">scheduled duration</span></div>
            <div class="schema-row"><span class="sr-field">waiting_room, require_auth</span><span class="sr-type">BOOLEAN</span><span class="sr-note"></span></div>
            <div class="schema-row"><span class="sr-field">auto_recording</span><span class="sr-type">ENUM</span><span class="sr-note">none|local|cloud</span></div>
            <div class="schema-row"><span class="sr-field">ai_transcription, my_notes_enabled</span><span class="sr-type">BOOLEAN</span><span class="sr-note"></span></div>
            <div class="schema-row"><span class="sr-field">recurrence</span><span class="sr-type">JSONB</span><span class="sr-note">{type, interval, end_date, occurrences}</span></div>
            <div class="schema-row"><span class="sr-field">settings</span><span class="sr-type">JSONB</span><span class="sr-note">additional meeting settings blob</span></div>
          </div>

          <div class="schema" style="margin-top:10px"><div class="schema-head">🟡 messages</div>
            <div class="schema-row"><span class="sr-field pk">id</span><span class="sr-type">UUID PK</span><span class="sr-note"></span></div>
            <div class="schema-row"><span class="sr-field fk">channel_id, sender_id, thread_parent_id</span><span class="sr-type">UUID FK</span><span class="sr-note">self-ref for threads</span></div>
            <div class="schema-row"><span class="sr-field">content</span><span class="sr-type">TEXT</span><span class="sr-note">Markdown / Yjs delta</span></div>
            <div class="schema-row"><span class="sr-field">type</span><span class="sr-type">ENUM</span><span class="sr-note">text|file|image|clip|system</span></div>
            <div class="schema-row"><span class="sr-field">attachments</span><span class="sr-type">JSONB[]</span><span class="sr-note">[{name, url, size, mime}]</span></div>
            <div class="schema-row"><span class="sr-field">reactions</span><span class="sr-type">JSONB</span><span class="sr-note">{"👍":[user_ids], "❤":[...]}</span></div>
            <div class="schema-row"><span class="sr-field">edited_at, pinned_at, deleted_at</span><span class="sr-type">TIMESTAMPTZ</span><span class="sr-note">deleted_at = soft delete</span></div>
          </div>

          <div class="schema" style="margin-top:10px"><div class="schema-head">🟡 meeting_recordings</div>
            <div class="schema-row"><span class="sr-field fk">meeting_id</span><span class="sr-type">UUID FK</span><span class="sr-note">→ meetings.id</span></div>
            <div class="schema-row"><span class="sr-field">storage_path</span><span class="sr-type">TEXT</span><span class="sr-note">S3 object key</span></div>
            <div class="schema-row"><span class="sr-field">format</span><span class="sr-type">ENUM</span><span class="sr-note">mp4|m4a|transcript_vtt|transcript_json|summary</span></div>
            <div class="schema-row"><span class="sr-field">ai_summary</span><span class="sr-type">TEXT</span><span class="sr-note">LLM-generated summary</span></div>
            <div class="schema-row"><span class="sr-field">ai_action_items</span><span class="sr-type">JSONB[]</span><span class="sr-note">[{text, assignee, due_date}]</span></div>
            <div class="schema-row"><span class="sr-field">smart_chapters</span><span class="sr-type">JSONB[]</span><span class="sr-note">[{timestamp, title, summary}]</span></div>
            <div class="schema-row"><span class="sr-field">share_url, share_passcode, share_expires_at</span><span class="sr-type">TEXT / TIMESTAMPTZ</span><span class="sr-note"></span></div>
          </div>
        </div>

        <!-- ── REDIS & KAFKA ── -->
        <div id="panel-redis" class="panel">
          <div class="ph1">Redis & Kafka</div>
          <div class="g2">
            <div class="card"><div class="ph3">Redis Usage</div><ul class="fl">
              <li><b>Session tokens</b> — JWT blocklist on logout (TTL = token expiry)</li>
              <li><b>Refresh tokens</b> — {userId:tokenHash} key, 7-day TTL, rotated on use</li>
              <li><b>Rate limiting</b> — sliding window per user/IP (100 req/min API, 10 req/s AI)</li>
              <li><b>Meeting rooms</b> — active room state, participant maps (TTL: meeting + 1h)</li>
              <li><b>Presence</b> — online/away/DND per user (TTL: 30s heartbeat)</li>
              <li><b>Cache</b> — user profiles, account settings (TTL: 5 min)</li>
              <li><b>Pub/Sub</b> — inter-service events (chat:new, presence:update)</li>
              <li><b>Distributed locks</b> — prevent double-recording, double-billing</li>
            </ul></div>
            <div class="card"><div class="ph3">Kafka Topics</div><ul class="fl">
              <li><code style="font-family:var(--mono);color:var(--green)">meeting.events</code> — started, ended, participant events</li>
              <li><code style="font-family:var(--mono);color:var(--green)">recording.completed</code> — triggers transcription pipeline</li>
              <li><code style="font-family:var(--mono);color:var(--green)">ai.transcription.chunk</code> — real-time transcript segments</li>
              <li><code style="font-family:var(--mono);color:var(--green)">ai.summary.request</code> — triggers LLM summary job</li>
              <li><code style="font-family:var(--mono);color:var(--green)">chat.message.new</code> — fan-out to notification service</li>
              <li><code style="font-family:var(--mono);color:var(--green)">user.events</code> — created, deactivated, role-changed</li>
              <li><code style="font-family:var(--mono);color:var(--green)">billing.events</code> — plan changed, seat added/removed</li>
              <li><code style="font-family:var(--mono);color:var(--green)">analytics.ingest</code> — usage metrics → ClickHouse</li>
              <li><code style="font-family:var(--mono);color:var(--green)">webhook.dispatch</code> — outbound customer webhook delivery</li>
            </ul></div>
          </div>
        </div>

        <!-- ── STORAGE ── -->
        <div id="panel-storage" class="panel">
          <div class="ph1">Storage & CDN</div>
          <div class="g2">
            <div class="card"><div class="ph3">S3 Bucket Structure</div><ul class="fl">
              <li><code style="font-family:var(--mono);color:var(--accent3)">recordings/{accountId}/{meetingId}/</code> — MP4, M4A, chat</li>
              <li><code style="font-family:var(--mono);color:var(--accent3)">transcripts/{meetingId}/</code> — .vtt, .json</li>
              <li><code style="font-family:var(--mono);color:var(--accent3)">summaries/{meetingId}/</code> — summary.json, chapters.json</li>
              <li><code style="font-family:var(--mono);color:var(--accent3)">uploads/{accountId}/{channelId}/</code> — chat file attachments</li>
              <li><code style="font-family:var(--mono);color:var(--accent3)">whiteboards/{boardId}/</code> — snapshots, exports</li>
              <li><code style="font-family:var(--mono);color:var(--accent3)">clips/{userId}/</code> — async video files</li>
              <li><code style="font-family:var(--mono);color:var(--accent3)">avatars/{userId}/</code> — profile pictures (CDN-distributed)</li>
              <li>Presigned URLs: 15 min for downloads, 60 min for uploads</li>
              <li>Lifecycle: recordings 90d → Glacier · transcripts: per retention policy</li>
            </ul></div>
            <div class="card"><div class="ph3">Recording Pipeline</div><ul class="fl">
              <li>SFU writes raw RTP tracks to S3 in real time (per-track segments)</li>
              <li>meeting.ended Kafka event triggers Lambda processor</li>
              <li>ECS Fargate task: FFmpeg mixes tracks → MP4 (active speaker) + M4A</li>
              <li>Outputs uploaded to recordings/ bucket</li>
              <li>recording.completed event → ai-companion-service consumer</li>
              <li>Whisper large-v3 transcription (Batch job, ~0.5× real-time speed)</li>
              <li>NLP: punctuation model, speaker diarization</li>
              <li>Claude API: generate summary + smart chapters + action items</li>
              <li>All AI outputs stored to summaries/ bucket + Postgres</li>
              <li>meeting.summary.completed webhook fired to customer endpoint</li>
            </ul></div>
          </div>
        </div>

        <!-- ── AI ARCHITECTURE ── -->
        <div id="panel-ai" class="panel">
          <div class="ph1">AI Architecture</div>
          <div class="pdesc">Federated model architecture. Model selection is dynamic based on task, latency requirements, and data privacy settings.</div>
          <div class="card" style="margin-bottom:14px">
            <table style="width:100%;border-collapse:collapse;font-size:13px">
              <thead><tr style="border-bottom:1px solid var(--border)">
                <th style="padding:8px 12px;text-align:left;color:var(--text3);font-size:11px;text-transform:uppercase">Task</th>
                <th style="padding:8px 12px;text-align:left;color:var(--text3);font-size:11px;text-transform:uppercase">Model</th>
                <th style="padding:8px 12px;text-align:left;color:var(--text3);font-size:11px;text-transform:uppercase">Provider</th>
                <th style="padding:8px 12px;text-align:left;color:var(--text3);font-size:11px;text-transform:uppercase">Mode</th>
              </tr></thead>
              <tbody>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-weight:600">Speech-to-Text</td><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">whisper-large-v3</td><td style="padding:8px 12px;color:var(--text2)">OpenAI</td><td style="padding:8px 12px"><span class="badge bg">Async</span></td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-weight:600">Meeting Summary</td><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">claude-3-5-sonnet</td><td style="padding:8px 12px;color:var(--text2)">Anthropic</td><td style="padding:8px 12px"><span class="badge bg">Async</span></td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-weight:600">In-Meeting Q&A</td><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">gpt-4o</td><td style="padding:8px 12px;color:var(--text2)">OpenAI</td><td style="padding:8px 12px"><span class="badge ba">Streaming SSE</span></td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-weight:600">Deep Research</td><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">gpt-4o + web search</td><td style="padding:8px 12px;color:var(--text2)">OpenAI</td><td style="padding:8px 12px"><span class="badge bp">Multi-step</span></td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-weight:600">Vector Embedding</td><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">text-embedding-3-large</td><td style="padding:8px 12px;color:var(--text2)">OpenAI</td><td style="padding:8px 12px"><span class="badge bg">Async</span></td></tr>
                <tr style="border-bottom:1px solid rgba(23,37,64,.5)"><td style="padding:8px 12px;font-weight:600">On-Device (E2EE)</td><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">nemotron-nano</td><td style="padding:8px 12px;color:var(--text2)">NVIDIA</td><td style="padding:8px 12px"><span class="badge bam">On-Device</span></td></tr>
                <tr><td style="padding:8px 12px;font-weight:600">Noise Suppression</td><td style="padding:8px 12px;font-family:var(--mono);color:var(--accent3);font-size:12px">RNNoise + custom</td><td style="padding:8px 12px;color:var(--text2)">Proprietary</td><td style="padding:8px 12px"><span class="badge bt">Real-Time</span></td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- ── SECURITY MODEL ── -->
        <div id="panel-security" class="panel">
          <div class="ph1">Security Model</div>
          <div class="g2">
            <div class="card"><div class="ph3">Transport</div><ul class="fl">
              <li>TLS 1.3 on all HTTPS (HSTS preloaded)</li>
              <li>DTLS-SRTP for all WebRTC media streams</li>
              <li>Certificate pinning on mobile apps</li>
              <li>CSP headers on all web responses</li>
              <li>CORS: strict origin allowlist only</li>
            </ul></div>
            <div class="card"><div class="ph3">Auth</div><ul class="fl">
              <li>JWT access tokens: RS256, 15 min expiry</li>
              <li>Refresh tokens: 7-day rotation, single-use</li>
              <li>OAuth 2.0 PKCE (mobile/SPA)</li>
              <li>SAML 2.0 SP-initiated SSO</li>
              <li>FIDO2 passkeys (WebAuthn level 2)</li>
              <li>TOTP + SMS MFA</li>
            </ul></div>
            <div class="card"><div class="ph3">Data</div><ul class="fl">
              <li>AES-256-GCM at rest (S3 SSE-KMS)</li>
              <li>Per-tenant KMS key (Enterprise)</li>
              <li>PostgreSQL RLS: tenant isolation</li>
              <li>PII masked in all application logs</li>
              <li>SOC 2 Type II, HIPAA, GDPR, FedRAMP</li>
            </ul></div>
            <div class="card"><div class="ph3">Meeting Security</div><ul class="fl">
              <li>E2E encryption: per-meeting AES-GCM key</li>
              <li>Passcode: bcrypt-hashed, never stored plain</li>
              <li>Waiting room: host-admitted only</li>
              <li>Deepfake detection: real-time synthetic media alert</li>
              <li>Recording consent: mandatory announcement</li>
            </ul></div>
          </div>
        </div>

        <!-- ── DEPLOYMENT ── -->
        <div id="panel-deploy" class="panel">
          <div class="ph1">Deployment & Infrastructure</div>
          <div class="g2">
            <div class="card"><div class="ph3">Kubernetes Setup</div><ul class="fl">
              <li>Multi-region: us-east-1, eu-west-1, ap-southeast-1</li>
              <li>EKS (AWS) — Helm chart per service</li>
              <li>Istio service mesh (mTLS, retries, circuit breakers)</li>
              <li>HPA: auto-scale on CPU + custom Kafka lag metric</li>
              <li>PodDisruptionBudget: min 2 replicas always running</li>
              <li>Node affinity: media/AI pods on GPU nodes</li>
              <li>Secrets: AWS Secrets Manager → External Secrets Operator</li>
            </ul></div>
            <div class="card"><div class="ph3">CI/CD Pipeline</div><ul class="fl">
              <li>GitHub Actions: lint → test → build → push image</li>
              <li>Docker images: multi-stage, distroless base (minimal attack surface)</li>
              <li>ArgoCD: GitOps deployment, auto-sync main branch</li>
              <li>Blue-green deployments for zero-downtime releases</li>
              <li>Canary: 5% → 20% → 100% traffic shift with automated rollback</li>
              <li>Smoke tests run post-deploy before full cutover</li>
            </ul></div>
            <div class="card"><div class="ph3">Observability</div><ul class="fl">
              <li>Metrics: Prometheus + Grafana (custom SLO dashboards)</li>
              <li>Tracing: OpenTelemetry → Jaeger (distributed traces)</li>
              <li>Logs: Fluent Bit → OpenSearch (structured JSON)</li>
              <li>Alerting: PagerDuty escalation on SLO breach</li>
              <li>Uptime: 99.9% SLA (Enterprise) · p50 API latency target: &lt;80ms</li>
              <li>Chaos engineering: Gremlin quarterly drills</li>
            </ul></div>
            <div class="card"><div class="ph3">Database Ops</div><ul class="fl">
              <li>PostgreSQL: primary + 2 read replicas per region</li>
              <li>WAL streaming replication (RPO: &lt;1s)</li>
              <li>PITR backups: every 5 min, 30-day retention</li>
              <li>Daily pg_dump to S3 (compressed, encrypted)</li>
              <li>RDS Proxy: connection pooling for Lambda / spiky traffic</li>
              <li>Schema migrations: Flyway, forward-only, PR-reviewed</li>
            </ul></div>
          </div>
        </div>

        <!-- ── INFRA ── -->
        <div id="panel-infra" class="panel">
          <div class="ph1">Infrastructure Map</div>
          <div class="card">
            <div class="infra-item"><div class="infra-dot" style="background:var(--accent2)"></div><div><div class="infra-title">API Gateway — Nginx + Node.js</div><div class="infra-desc">TLS termination, rate limiting (100 req/min per user), JWT validation, service routing, request logging</div></div></div>
            <div class="infra-item"><div class="infra-dot" style="background:var(--green)"></div><div><div class="infra-title">WebRTC Cluster — Mediasoup on Rust</div><div class="infra-desc">SFU nodes per region, auto-scaled, dedicated GPU instances for noise suppression and real-time transcription</div></div></div>
            <div class="infra-item"><div class="infra-dot" style="background:var(--purple)"></div><div><div class="infra-title">STUN/TURN — coturn on anycast IPs</div><div class="infra-desc">10 regional TURN servers (US×3, EU×3, APAC×3, SA×1), UDP 3478 + TCP 443 fallback, 10 Gbps capacity</div></div></div>
            <div class="infra-item"><div class="infra-dot" style="background:var(--amber)"></div><div><div class="infra-title">Kafka Cluster — 3 brokers per region</div><div class="infra-desc">Replication factor 3, min.insync.replicas 2, retention 7 days, Kafka Connect for ClickHouse sink</div></div></div>
            <div class="infra-item"><div class="infra-dot" style="background:var(--teal)"></div><div><div class="infra-title">Redis Cluster — 6 nodes (3 primary, 3 replica)</div><div class="infra-desc">Cluster mode, AOF persistence, maxmemory-policy allkeys-lru, 64 GB total, Sentinel failover &lt;30s</div></div></div>
            <div class="infra-item"><div class="infra-dot" style="background:var(--pink)"></div><div><div class="infra-title">CDN — CloudFront + Fastly (dual-stack)</div><div class="infra-desc">HLS streaming for recordings, signed URLs with 15-min TTL, edge caching of popular recordings, 450+ PoPs</div></div></div>
            <div class="infra-item"><div class="infra-dot" style="background:var(--orange)"></div><div><div class="infra-title">AI Processing — ECS Fargate GPU tasks</div><div class="infra-desc">On-demand Fargate tasks for Whisper transcription and FFmpeg mixing. Scale to zero when idle. p3.2xlarge for heavy AI</div></div></div>
          </div>
        </div>

        <!-- ── MEDIA PIPELINE ── -->
        <div id="panel-media" class="panel">
          <div class="ph1">Media Processing Pipeline</div>
          <div class="card">
            <ul class="fl">
              <li><b>Step 1</b> — Mediasoup SFU records individual participant RTP tracks (per-track segmented files) directly to S3 during the meeting</li>
              <li><b>Step 2</b> — On <code style="font-family:var(--mono);color:var(--green)">meeting.ended</code> Kafka event, Lambda triggers an ECS Fargate task</li>
              <li><b>Step 3</b> — FFmpeg mixes all tracks: Active Speaker MP4 (video+audio), Gallery View MP4, Audio-only M4A, Chat transcript TXT</li>
              <li><b>Step 4</b> — Mixed files uploaded to <code style="font-family:var(--mono);color:var(--accent3)">recordings/{accountId}/{meetingId}/</code> S3 bucket</li>
              <li><b>Step 5</b> — <code style="font-family:var(--mono);color:var(--green)">recording.completed</code> Kafka event consumed by ai-companion-service</li>
              <li><b>Step 6</b> — Audio extracted → Whisper large-v3 transcription (AWS Batch, ~0.5× real-time)</li>
              <li><b>Step 7</b> — NLP pipeline: punctuation model, speaker diarization (assign speaker labels by voice)</li>
              <li><b>Step 8</b> — Transcript stored as VTT + JSON to S3, written to Postgres (transcript_status → completed)</li>
              <li><b>Step 9</b> — Claude API: generate summary, smart chapters, extract action items, identify key decisions</li>
              <li><b>Step 10</b> — All AI outputs written to Postgres + S3 summaries bucket</li>
              <li><b>Step 11</b> — <code style="font-family:var(--mono);color:var(--green)">meeting.summary.completed</code> webhook dispatched to customer endpoint</li>
              <li><b>Step 12</b> — Socket.io push <code style="font-family:var(--mono);color:var(--green)">ai:summary-ready</code> to host's connected clients</li>
              <li>Total pipeline time: ~3–8 minutes for a 1-hour meeting</li>
            </ul>
          </div>
        </div>

      </div><!-- /content -->
    </div><!-- /app-main -->
  </div><!-- /app-layout -->
</div><!-- /app-screen -->

<script>
const CREDS = {'dev@fasafas.com':'Backend@2026','developer':'Backend@2026','devadmin':'Dev#FasaFas26'};

function doLogin(){
  const u=document.getElementById('l-user').value.trim();
  const p=document.getElementById('l-pass').value;
  const btn=document.getElementById('login-btn');
  const err=document.getElementById('login-error');
  if(!u||!p){showErr('Please enter username and password.');return;}
  btn.disabled=true;btn.textContent='Verifying access…';
  err.classList.remove('show');
  setTimeout(()=>{
    if(CREDS[u]===p){
      btn.textContent='✓ Access Granted — Loading portal…';
      btn.style.background='linear-gradient(135deg,#059669,#0d9488)';
      setTimeout(()=>{
        document.getElementById('login-screen').style.display='none';
        document.getElementById('app-screen').style.display='block';
        showToast('Developer portal unlocked 🔓');
      },700);
    } else {
      showErr('Access denied. Invalid developer credentials.');
      btn.disabled=false;btn.textContent='Access Developer Portal →';btn.style.background='';
      document.getElementById('l-pass').value='';
      document.getElementById('l-pass').focus();
    }
  },900);
}

function showErr(msg){
  document.getElementById('err-msg').textContent=msg;
  document.getElementById('login-error').classList.add('show');
}

function doLogout(){
  if(confirm('Sign out of the developer portal?')){
    document.getElementById('app-screen').style.display='none';
    document.getElementById('login-screen').style.display='flex';
    document.getElementById('l-user').value='';document.getElementById('l-pass').value='';
    document.getElementById('login-btn').textContent='Access Developer Portal →';
    document.getElementById('login-btn').style.background='';
    document.getElementById('login-btn').disabled=false;
    document.getElementById('login-error').classList.remove('show');
  }
}

function fill(id,val){document.getElementById(id).value=val;showToast('Field filled — click Access Developer Portal');}
function togglePw(){const i=document.getElementById('l-pass'),b=event.currentTarget;i.type=i.type==='password'?'text':'password';b.textContent=i.type==='password'?'👁':'🙈';}

const titles={
  overview:['🗂','Architecture Overview'],stack:['🧱','Tech Stack'],services:['⚙️','Microservices'],
  infra:['☁️','Infrastructure'],rest:['🔌','REST Endpoints'],websocket:['⚡','WebSocket / WebRTC'],
  webhooks:['🔗','Webhooks'],schema:['🗄️','Database Schema'],redis:['⚡','Redis & Kafka'],
  storage:['📦','Storage & CDN'],ai:['🤖','AI Architecture'],media:['🎬','Media Pipeline'],
  security:['🔒','Security Model'],deploy:['🚀','Deployment']
};

function sw(id,el){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.sb-item').forEach(n=>n.classList.remove('active'));
  const panel=document.getElementById('panel-'+id);
  if(panel)panel.classList.add('active');
  if(el)el.classList.add('active');
  const meta=titles[id]||['📄',id];
  document.getElementById('tb-icon').textContent=meta[0];
  document.getElementById('tb-title').textContent=meta[1];
}

function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

document.addEventListener('keydown',e=>{
  if(e.key==='Enter'&&document.getElementById('login-screen').style.display!=='none')doLogin();
});
</script>
<script src="../assets/js/translate.js"></script>
</body>
</html>
